rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPING PHASE
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read, write: if isAdmin() || isSignedIn(); 
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() || isSignedIn(); 
    }

    match /orders/{orderId} {
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /resales/{resaleId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // السماح بالوصول العام لقراءة إعدادات البروتوكول (مثل PoW)
      allow write: if isAdmin();
    }
  }
}